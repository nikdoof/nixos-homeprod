        "sortBy": [{ "desc": false, "displayName": "Host" }]
      },
      "pluginVersion": "12.3.5",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "(nixos_flake_revision == on(host) group_left(revision) max by (host) (nixos_flake_revision)) * 1000",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Host Revisions",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": { "Value": 2, "host": 0, "revision": 1 },
            "renameByName": {
              "Value": "Activated",
              "host": "Host",
              "revision": "Revision"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
